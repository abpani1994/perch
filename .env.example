# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=perch
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=perch

# ── App ───────────────────────────────────────────────────────────────────
# DATABASE_URL is assembled in docker-compose from the POSTGRES_* values above.
DATABASE_URL=postgresql://perch:change_me_in_production@db:5432/perch?schema=public

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=

CLIENT_URL=http://localhost:4000

# ── Stripe (Pro subscription) — leave empty to run "not connected" ──────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=